# Argus Configuration — fill these in before `docker compose up -d`.

# ------------------------------------------------------------
# Seed mode (controls the one-shot ``argus-seed`` service)
# ------------------------------------------------------------
# none        — skip seeding entirely. Schema migrates, no rows inserted.
#               Use for restores or air-gapped imports of pre-built data.
# minimal     — (default) system organisation + admin user only.
#               Production-style. Dashboards render documented empty
#               states until the operator adds real assets/feeds.
# realistic   — full demo dataset across every screen: 4 orgs, ~50 IOCs,
#               threat actors with sightings, MITRE catalogue subset,
#               TPRM scorecards, BIN registry, brand logos, news,
#               advisories, sample reports, DMARC reports, audit history.
#               Use for sales walkthroughs and end-to-end demos.
# stress      — realistic + higher cardinality (reserved; behaves like
#               realistic today). Use for performance/UX validation.
ARGUS_SEED_MODE=minimal

# Set to 1 by start.sh after the first successful boot. Tells subsequent
# ./start.sh runs to skip argus-seed (data persists in the postgres volume).
# Cleared automatically by ./start.sh wipe. Do not set manually.
ARGUS_SEEDED=

# Bootstrap credentials (used by ``minimal`` / ``realistic`` seed when
# the user does not yet exist). Optional — defaults are auto-generated
# and printed once to the seed log so the operator can rotate
# immediately after first login. Set these to ship a known credential
# (e.g. on Railway, set them as project env vars before the first
# deploy so you don't have to scrape the seed log).
#
# In ``minimal`` mode only ARGUS_BOOTSTRAP_ADMIN_* is honored. In
# ``realistic`` mode both ADMIN and ANALYST creds get applied to the
# Demo Bank's demo-admin@argus.test and demo-analyst@argus.test users
# (or override the email entirely with ARGUS_BOOTSTRAP_*_EMAIL).
ARGUS_BOOTSTRAP_ADMIN_EMAIL=
ARGUS_BOOTSTRAP_ADMIN_PASSWORD=
ARGUS_BOOTSTRAP_ANALYST_EMAIL=
ARGUS_BOOTSTRAP_ANALYST_PASSWORD=

# ------------------------------------------------------------
# Human-in-the-loop guard (FIRST PRINCIPLE)
# ------------------------------------------------------------
# Argus is built on the principle that no agent ever takes an
# external or state-mutating action without an analyst's explicit
# approval. ARGUS_AGENT_HUMAN_IN_LOOP_REQUIRED is the master kill-
# switch; while it's "true" (the default), every auto-* feature
# below is refused regardless of its individual flag.
#
# Operators in regulated environments (banks, healthcare, gov) MUST
# leave this on. Only flip to "false" with explicit documented
# authorisation — the bypass is audited but the audit log is your
# only paper trail.
ARGUS_AGENT_HUMAN_IN_LOOP_REQUIRED=true

# ------------------------------------------------------------
# Per-feature auto-action flags (only consulted when the master
# guard above is "false")
# ------------------------------------------------------------
# When ``Investigation`` completes with severity="critical", auto-
# promote into a Case row instead of waiting for the analyst's
# Promote button.
ARGUS_AGENT_AUTO_PROMOTE=false

# When Brand Defender returns recommendation=takedown_now with
# confidence ≥ 0.95, file the takedown ticket without a human
# clicking Submit. Highest-stakes auto-action — read the audit logs
# regularly if you turn this on.
ARGUS_AGENT_AUTO_TAKEDOWN=false

# Internal routing — chain Investigation → Threat Hunter when an
# investigation completes critical with correlated actors. Doesn't
# mutate external state, so it's not gated by HIL_REQUIRED. Per-org
# veto via the agent settings table.
ARGUS_AGENT_CHAIN_INVESTIGATION_TO_HUNT=true

# ------------------------------------------------------------
# Tenant identity (single-tenant install)
# ------------------------------------------------------------
# Slugified organisation name. Leave blank to use the
# first-provisioned organisation. Set explicitly when the
# database may have multiple rows (e.g. after a restore).
ARGUS_SYSTEM_ORGANIZATION_SLUG=

# ------------------------------------------------------------
# Application
# ------------------------------------------------------------
ARGUS_DEBUG=false
ARGUS_LOG_LEVEL=INFO
ARGUS_JWT_SECRET=
# Comma-separated list of allowed origins for the dashboard.
# Empty = same-origin only (most secure default).
ARGUS_CORS_ORIGINS=

# ------------------------------------------------------------
# Database
# ------------------------------------------------------------
ARGUS_DB_HOST=postgres
ARGUS_DB_PORT=5432
ARGUS_DB_NAME=argus
ARGUS_DB_USER=argus
# REQUIRED — no default. Argus will refuse to start if this is unset.
ARGUS_DB_PASSWORD=

# ------------------------------------------------------------
# Redis (rate limiting, login lockout, dedup windows)
# ------------------------------------------------------------
ARGUS_REDIS_HOST=redis
ARGUS_REDIS_PORT=6379

# ------------------------------------------------------------
# MinIO / Evidence vault
# ------------------------------------------------------------
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=
ARGUS_EVIDENCE_ENDPOINT_URL=http://minio:9000
ARGUS_EVIDENCE_ACCESS_KEY=
ARGUS_EVIDENCE_SECRET_KEY=
ARGUS_EVIDENCE_BUCKET=argus-evidence

# ------------------------------------------------------------
# LLM (default: local Ollama; data never leaves the host)
# ------------------------------------------------------------
# To stay air-gap-clean, run an Ollama container alongside Argus
# and leave these defaults. To use an OpenAI-compatible endpoint
# (Azure OpenAI, on-prem vLLM, OpenAI proper), set provider=openai
# and supply BOTH base_url and api_key — Argus refuses to dispatch
# without credentials rather than silently degrading.
ARGUS_LLM_PROVIDER=ollama
ARGUS_LLM_BASE_URL=http://ollama:11434
ARGUS_LLM_MODEL=llama3.1:8b
ARGUS_LLM_API_KEY=
ARGUS_LLM_REQUEST_TIMEOUT_SECONDS=120
ARGUS_LLM_MAX_CONCURRENT_CALLS=4

# ------------------------------------------------------------
# Tor (used by tor / forum / ransomware / stealer crawlers)
# ------------------------------------------------------------
ARGUS_TOR_SOCKS_HOST=tor
ARGUS_TOR_SOCKS_PORT=9050
ARGUS_TOR_CONTROL_PORT=9051
# REQUIRED — must match the PASSWORD set in the tor service.
# Generate: openssl rand -hex 16
ARGUS_TOR_CONTROL_PASSWORD=

# ------------------------------------------------------------
# Crawler tuning (request pacing, identity rotation)
# ------------------------------------------------------------
ARGUS_CRAWLER_MAX_CONCURRENT=5
ARGUS_CRAWLER_REQUEST_DELAY_MIN=2.0
ARGUS_CRAWLER_REQUEST_DELAY_MAX=8.0

# ------------------------------------------------------------
# Threat-intel feeds (each is opt-in; missing = feed disabled)
# Argus records a FeedHealth row on every run so a missing key
# surfaces in /api/v1/feed-health and the dashboard, never as a
# silent zero.
# ------------------------------------------------------------
ARGUS_FEED_OTX_API_KEY=
ARGUS_FEED_GREYNOISE_API_KEY=
ARGUS_FEED_ABUSEIPDB_API_KEY=
ARGUS_FEED_ABUSE_CH_API_KEY=
ARGUS_FEED_MAXMIND_LICENSE_KEY=
# Cloudflare API token with radar:read scope (enables BGP hijack detection)
# Create at: https://dash.cloudflare.com/profile/api-tokens
ARGUS_FEED_CF_RADAR_API_KEY=

# ------------------------------------------------------------
# Takedown partners (each adapter refuses to run if credentials
# are missing — no silent stubs)
# ------------------------------------------------------------
ARGUS_TAKEDOWN_NETCRAFT_API_KEY=

ARGUS_TAKEDOWN_PHISHLABS_SMTP_RECIPIENT=
ARGUS_TAKEDOWN_PHISHLABS_ACCOUNT_REFERENCE=

ARGUS_TAKEDOWN_GROUPIB_SMTP_RECIPIENT=
ARGUS_TAKEDOWN_GROUPIB_ACCOUNT_REFERENCE=

# Internal-legal: comma-separated mailbox list AND/OR Jira
# credentials. The adapter dispatches to whichever is configured.
ARGUS_TAKEDOWN_INTERNAL_LEGAL_SMTP_RECIPIENTS=
ARGUS_TAKEDOWN_INTERNAL_LEGAL_JIRA_URL=
ARGUS_TAKEDOWN_INTERNAL_LEGAL_JIRA_USER=
ARGUS_TAKEDOWN_INTERNAL_LEGAL_JIRA_TOKEN=
ARGUS_TAKEDOWN_INTERNAL_LEGAL_JIRA_PROJECT=

# ------------------------------------------------------------
# Notifications (each adapter is independent; configure what you use)
# ------------------------------------------------------------
ARGUS_NOTIFY_SLACK_WEBHOOK_URL=
ARGUS_NOTIFY_EMAIL_SMTP_HOST=
ARGUS_NOTIFY_EMAIL_SMTP_PORT=587
ARGUS_NOTIFY_EMAIL_SMTP_USER=
ARGUS_NOTIFY_EMAIL_SMTP_PASSWORD=
ARGUS_NOTIFY_EMAIL_FROM=argus@example.com
ARGUS_NOTIFY_EMAIL_TO=
ARGUS_NOTIFY_PAGERDUTY_ROUTING_KEY=

# ------------------------------------------------------------
# Meilisearch (full-text IOC / intel search)
# REQUIRED in production — Meilisearch runs in authenticated mode.
# Generate: openssl rand -hex 32
# ------------------------------------------------------------
MEILI_MASTER_KEY=

# ------------------------------------------------------------
# NVD (optional API key raises rate limit from 50→2000 req/30s)
# Register at: https://nvd.nist.gov/developers/request-an-api-key
# ------------------------------------------------------------
ARGUS_NVD_API_KEY=
# How many days back to look for modified CVEs on each daily sync (default 1).
ARGUS_NVD_LOOKBACK_DAYS=1

# ------------------------------------------------------------
# Operational keys surfaced by adversarial audit D-28
# ------------------------------------------------------------
# Hard cap on inbound request body size (bytes). Default 10 MiB.
ARGUS_MAX_REQUEST_BYTES=10485760

# Optional alias for ARGUS_DB_PASSWORD when an operator is forced to use
# a single DATABASE_URL (Heroku/Railway-style). When set, it takes
# precedence over the discrete ARGUS_DB_* fields. Leave blank to keep
# using the discrete fields above.
DATABASE_URL=

# An additional symmetric secret used for at-rest encryption of
# integration credentials and notification channel secrets (see
# src/core/crypto.py). REQUIRED in production. Generate:
#   openssl rand -hex 32
ARGUS_SECRET_KEY=

# When "true", src/core/url_safety lets webhook / probe URLs target
# private (RFC1918) and loopback ranges. ONLY enable for a fully
# air-gapped lab — production must leave this off (default).
ARGUS_URL_SAFETY_ALLOW_PRIVATE=false

# Lokinet daemon health endpoint — used by the Lokinet crawler to
# refuse to start if the daemon isn't reachable.
ARGUS_LOKINET_HEALTH_HOST=http://127.0.0.1:1190

# PDF report generator fonts (DejaVuSans-style) — leave blank to use
# the bundled fonts in the Docker image.
ARGUS_PDF_FONT_PATH=
ARGUS_PDF_FONT_BOLD_PATH=

# Where the report generator writes finished PDFs. Mounted volume in
# Docker. Defaults to /var/lib/argus/reports.
ARGUS_REPORTS_DIR=/var/lib/argus/reports

# Worker liveness — heartbeat file path + max age (seconds) for the
# Docker HEALTHCHECK. Healthcheck fails when the file is older than
# max_age, so the container restarts.
ARGUS_WORKER_HEARTBEAT=/tmp/argus-worker.heartbeat
ARGUS_WORKER_HEARTBEAT_MAX_AGE=600

# Worker scheduler snapshot — path to the JSON file the scheduler worker
# writes on every tick. The /api/v1/scheduler-status endpoint reads this
# to report running job kinds without a live DB query. Set to a path on a
# volume shared between the api and worker containers.
ARGUS_WORKER_SCHEDULER_SNAPSHOT=/var/lib/argus/scheduler-snapshot.json

# certstream daemon — set to "true" to subscribe to the public
# certificate-transparency feed for certstream-based monitoring. Off
# by default because the upstream feed has no auth and burns
# bandwidth.
ARGUS_WORKER_CERTSTREAM_ENABLED=false

# LinkedIn / Twitter monitor credentials — leave blank to disable
# those monitors. Twitter expects a session directory persisted by
# tweepy/snscrape (per Twitter's anti-scraping posture); LinkedIn
# expects a username + password the monitor will log in with.
ARGUS_LINKEDIN_USERNAME=
ARGUS_LINKEDIN_PASSWORD=
ARGUS_TWITTER_SESSION_DIR=
