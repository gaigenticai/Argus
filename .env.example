# Argus Configuration
ARGUS_DEBUG=true
ARGUS_LOG_LEVEL=INFO

# Database
ARGUS_DB_HOST=localhost
ARGUS_DB_PORT=5432
ARGUS_DB_NAME=argus
ARGUS_DB_USER=argus
ARGUS_DB_PASSWORD=argus

# Redis
ARGUS_REDIS_HOST=localhost
ARGUS_REDIS_PORT=6379

# Tor
ARGUS_TOR_SOCKS_HOST=localhost
ARGUS_TOR_SOCKS_PORT=9050
ARGUS_TOR_CONTROL_PORT=9051
ARGUS_TOR_CONTROL_PASSWORD=argus

# LLM (z.ai — OpenAI-compatible)
ARGUS_LLM_PROVIDER=openai
ARGUS_LLM_BASE_URL=https://api.z.ai/api/coding/paas/v4
ARGUS_LLM_MODEL=glm-5
ARGUS_LLM_API_KEY=your-api-key-here

# Crawler
ARGUS_CRAWLER_MAX_CONCURRENT=5
ARGUS_CRAWLER_REQUEST_DELAY_MIN=2.0
ARGUS_CRAWLER_REQUEST_DELAY_MAX=8.0

# Notifications (all optional)
# ARGUS_NOTIFY_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx
# ARGUS_NOTIFY_EMAIL_SMTP_HOST=smtp.gmail.com
# ARGUS_NOTIFY_EMAIL_SMTP_PORT=587
# ARGUS_NOTIFY_EMAIL_SMTP_USER=
# ARGUS_NOTIFY_EMAIL_SMTP_PASSWORD=
# ARGUS_NOTIFY_EMAIL_FROM=argus@yourcompany.com
# ARGUS_NOTIFY_EMAIL_TO=["security@yourcompany.com"]
# ARGUS_NOTIFY_PAGERDUTY_ROUTING_KEY=
